---
// Problém → řešení (§7.2) — 3 stručné body
const items = [
  {
    icon: '💸',
    problem: 'Drahá a nepřetržitá recepce',
    solution: 'Samoobslužný kiosek, online check-in a self check-in zvládnou provoz i bez nočního personálu.',
  },
  {
    icon: '📵',
    problem: 'Přebookování a roztříštěné nástroje',
    solution: 'Kalendář obsazení, plán pokojů a import OTA kalendářů hlídají volné jednotky — vše v jednom systému.',
  },
  {
    icon: '🌍',
    problem: 'Jazyková bariéra a administrativa cizinců',
    solution: '11 jazyků napříč celým systémem, UBYPORT export, evidenční kniha a GDPR retence.',
  },
];
---

<section class="section bg-mist-light">
  <div class="container-tight">
    <div class="reveal mx-auto max-w-2xl text-center">
      <span class="eyebrow">Proč ReceptionAI</span>
      <h2 class="mt-4 text-3xl font-bold text-navy sm:text-4xl">Méně starostí na recepci, víc času na hosty</h2>
      <p class="mt-4 text-lg text-navy/65">Tři nejčastější bolesti ubytovacích provozů — a jak je ReceptionAI řeší.</p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {items.map((item, i) => (
        <div class="reveal group rounded-3xl bg-white p-8 shadow-card transition-all duration-300 hover:-translate-y-1 hover:shadow-card-hover" style={`transition-delay:${i * 90}ms`}>
          <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-mist text-3xl">{item.icon}</div>
          <h3 class="mt-6 text-lg font-bold text-navy">{item.problem}</h3>
          <div class="mt-3 flex items-start gap-2 text-navy/70">
            <span class="mt-0.5 text-gold-dark">→</span>
            <p>{item.solution}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
