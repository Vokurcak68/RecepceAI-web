---
import { steps } from '../data/site';
// Jak to funguje (§7.4) — 4 kroky
---

<section id="jak-to-funguje" class="section bg-mist-light">
  <div class="container-tight">
    <div class="reveal mx-auto max-w-2xl text-center">
      <span class="eyebrow">Jak to funguje</span>
      <h2 class="mt-4 text-3xl font-bold text-navy sm:text-4xl">Od příjezdu hosta po hodnocení</h2>
      <p class="mt-4 text-lg text-navy/65">Celý pobyt v jednom plynulém toku — bez papírování a čekání u pultu.</p>
    </div>

    <ol class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      {steps.map((step, i) => (
        <li class="reveal relative" style={`transition-delay:${i * 90}ms`}>
          {i < steps.length - 1 && (
            <span class="absolute left-7 top-7 hidden h-px w-full bg-gradient-to-r from-gold/50 to-transparent lg:block" aria-hidden="true"></span>
          )}
          <div class="relative flex h-14 w-14 items-center justify-center rounded-full bg-navy font-display text-lg font-bold text-gold-light shadow-card">
            {step.num}
          </div>
          <h3 class="mt-5 text-lg font-bold text-navy">{step.title}</h3>
          <p class="mt-2 text-navy/65">{step.desc}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
