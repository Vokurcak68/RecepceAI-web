---
import { faqs } from '../data/site';
// FAQ (§7.10)
---

<section id="faq" class="section bg-white">
  <div class="container-tight max-w-3xl">
    <div class="reveal text-center">
      <span class="eyebrow">FAQ</span>
      <h2 class="mt-4 text-3xl font-bold text-navy sm:text-4xl">Časté dotazy</h2>
      <p class="mt-4 text-lg text-navy/65">Co se nejčastěji ptají provozovatelé před nasazením.</p>
    </div>

    <div class="reveal mt-12 space-y-3">
      {faqs.map((faq) => (
        <details class="group rounded-2xl border border-navy/[0.07] bg-mist-light px-6 py-1 transition-colors open:bg-white open:shadow-card">
          <summary class="flex cursor-pointer list-none items-center justify-between py-5 text-left font-semibold text-navy marker:hidden">
            {faq.q}
            <span class="ml-4 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-gold/15 text-gold-dark transition-transform duration-200 group-open:rotate-45">
              +
            </span>
          </summary>
          <p class="pb-5 pr-10 text-navy/70">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
})} />
