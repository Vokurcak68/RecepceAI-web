<?xml version="1.0" encoding="UTF-8"?>
<!--
  Konfigurace pro hosting statického webu na IIS (Windows).
  Soubor je v `public/`, takže ho Astro při buildu zkopíruje do kořene `dist/`.
  Web je čistě statický — neběží na žádném portu, IIS ho servíruje ze souborů.
-->
<configuration>
  <system.webServer>

    <!-- Výchozí dokument (pro adresářové cesty /gdpr/, /dekujeme/) -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- MIME typy, které starší IIS nemusí znát -->
    <staticContent>
      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
      <remove fileExtension=".webmanifest" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <remove fileExtension=".xml" />
      <mimeMap fileExtension=".xml" mimeType="application/xml" />
    </staticContent>

    <!-- Vlastní 404 stránka (zachová status 404) -->
    <httpErrors errorMode="Custom" existingResponse="Replace">
      <remove statusCode="404" />
      <error statusCode="404" path="404.html" responseMode="File" />
    </httpErrors>

    <!-- Komprese statického obsahu (HTML/CSS/JS) -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    <rewrite>
      <rules>
        <!-- Kontaktní formulář: reverzní proxy (ARR) na lokální mailovou službu -->
        <rule name="api-contact-proxy" stopProcessing="true">
          <match url="^api/contact/?$" />
          <action type="Rewrite" url="http://127.0.0.1:8090/contact" />
        </rule>

        <!--
          Volitelné: HTTP→HTTPS a www→apex přesměrování (zapni odkomentováním).
          Pozn.: SSL zde terminuje přední vrstva, proto ponecháno vypnuté.
        <rule name="www to apex" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTP_HOST}" pattern="^www\.recepceai\.cz$" />
          </conditions>
          <action type="Redirect" url="https://recepceai.cz/{R:1}" redirectType="Permanent" />
        </rule>
        -->
      </rules>
    </rewrite>

  </system.webServer>

  <!-- Dlouhá cache pro hashované assety v /_astro/ (názvy obsahují hash) -->
  <location path="_astro">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" cacheControlCustom="public, immutable" />
      </staticContent>
    </system.webServer>
  </location>
</configuration>
